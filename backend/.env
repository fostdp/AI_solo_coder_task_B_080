# 古罗马水道工程结构健康与现代修复评估系统
# 环境配置文件 - Docker Compose 运行时，HOST 名使用服务名

# TimescaleDB Configuration
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=postgres
TIMESCALE_DB=aqueduct_monitor

# MQTT Broker Configuration
MQTT_BROKER=tcp://mosquitto:1883
MQTT_CLIENT_ID=aqueduct_monitor
MQTT_USERNAME=admin
MQTT_PASSWORD=admin
MQTT_ALERT_TOPIC=aqueduct/alerts

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Evaluation Thresholds
LOAD_CAPACITY_THRESHOLD=0.50
SETTLEMENT_LIMIT_MM=20.0
WEATHERING_ACCELERATION_RATIO=1.5

# ─────────────────────────────────────────────────────────────
# 9. 监控与性能配置
# ─────────────────────────────────────────────────────────────

# pprof 调试端口（可选，如需独立监听时用，默认集成在主端口的 /debug/pprof）
PPROF_ENABLED=true

# FEA 有限元参数 - 三铰拱解析模型 + 自适应网格
FEA_MAX_ITERATIONS=50
FEA_TOLERANCE=0.0001
FEA_RELAXATION=0.5
FEA_MIN_ELEMENTS=6
FEA_MAX_ELEMENTS=32
FEA_CURVATURE_THRESH=0.15
FEA_BASE_CONCRETE_FY=15.0
FEA_BASE_STONE_FY=12.0
FEA_BASE_EMOD=25000.0
FEA_WEATHERING_POWER=1.3
FEA_AGE_BASE=0.85
FEA_AGE_RATE=0.15
FEA_AQUEDUCT_AGE=2000
FEA_FOUNDATION_K=1000000.0
FEA_PIER_ROT_LIMIT=0.02

# MADM 多属性决策参数
MADM_KNN_NEIGHBORS=3
MADM_MISSING_PENALTY=0.7
MADM_MISSING_THRESHOLD=0.4
MADM_SENSITIVITY_PERTURB=0.20

# Pipeline 管道配置
PIPE_BUFFER_SIZE=200
PIPE_WORKERS_EVAL=4
PIPE_WORKERS_REPAIR=2
PIPE_WORKERS_ALARM=2
